<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_secondary"
    android:orientation="vertical"
    android:padding="16dp"
    android:paddingTop="24dp"
    android:fitsSystemWindows="true"
    android:weightSum="100">

    <ScrollView
        android:id="@+id/input_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="67"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@color/dbx_blue_500"
        android:fadeScrollbars="false"
        android:scrollbarSize="4dp">

        <LinearLayout
            android:id="@+id/input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/section_background"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <!-- Header: Input + Logo -->
            <LinearLayout
                android:id="@+id/input_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/input_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/input_title"
                    android:textColor="@color/dbx_blue_700"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/input_logo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/label_logo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/bricksy_logo" />
            </LinearLayout>

            <!-- Section: Car Telemetry Information -->
            <TextView
                android:id="@+id/label_telemetry_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/label_telemetry_section"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <!-- Row: Vehicle, AC Temp, Engine Temp -->
            <LinearLayout
                android:id="@+id/row_vehicle_temps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_vehicle"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/spinner_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dropdown" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_ac_temperature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_ac_temp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_ac_temperature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_engine_temperature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_engine_temp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_engine_temperature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row: TPMS FL, FR, BL, BR -->
            <LinearLayout
                android:id="@+id/row_tpms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_tpms_front_left"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tpms_front_left"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_tpms_front_left"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_tpms_front_right"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tpms_front_right"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_tpms_front_right"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_tpms_back_left"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tpms_back_left"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_tpms_back_left"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/label_tpms_back_right"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tpms_back_right"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/input_tpms_back_right"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_numeric"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row: Engine Start/Stop + Diagnose -->
            <LinearLayout
                android:id="@+id/row_engine_diagnose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/button_engine_toggle"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="16dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/label_engine_toggle"
                    android:scaleType="fitCenter"
                    android:src="@drawable/engine_off" />

                <Button
                    android:id="@+id/button_diagnose"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:gravity="center"
                    android:text="@string/action_diagnose"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/border_subtle" />

            <!-- Section: Driver Interactions -->
            <TextView
                android:id="@+id/label_driver_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/label_driver_section"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <!-- Row: Driver Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/label_driver_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_driver_name"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/input_driver_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_driver_name"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />
            </LinearLayout>

            <!-- Row: New Session + Voice Record -->
            <LinearLayout
                android:id="@+id/row_driver_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/button_new_session"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_ghost"
                    android:gravity="center"
                    android:text="@string/action_new_session"
                    android:textAllCaps="false"
                    android:textColor="@color/dbx_orange"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/button_voice_record"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:gravity="center"
                    android:text="@string/action_voice_record"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/output_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="33"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@color/dbx_blue_500"
        android:fadeScrollbars="false"
        android:scrollbarSize="4dp">

        <LinearLayout
            android:id="@+id/output_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/section_background"
            android:orientation="vertical">

            <TextView
                android:id="@+id/output_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/output_title"
                android:textColor="@color/dbx_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/output_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/output_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/output_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/output_default"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
